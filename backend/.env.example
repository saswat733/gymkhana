NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database — use DATABASE_URL (Neon) OR separate DB_* vars
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gymkhana
DB_USER=postgres
DB_PASSWORD=
DB_LOGGING=false

# JWT
JWT_ACCESS_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info

# Seed admin
SEED_ADMIN_EMAIL=admin@gymkhana.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Super Admin

# Email (Phase 2.1)
EMAIL_PROVIDER=console
EMAIL_DRY_RUN=false
EMAIL_FROM=no-reply@gymkhana.local
# RESEND_API_KEY=re_xxxxxxxx  # when EMAIL_PROVIDER=resend

# Razorpay (member + SaaS payments)
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=xxx

# Dev only: allow POST /subscriptions/self without payment (never enable in production)
# ALLOW_FREE_SELF_SUBSCRIBE=true

